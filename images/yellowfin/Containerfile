# yellowfin:gnome50 — Fedora bootc image with GNOME 50 and system-mode RDP
# via gnome-remote-desktop (grdctl --system), available at the GDM login screen.
FROM quay.io/fedora/fedora-bootc:42@sha256:927960c6b65923d6dfd6ad30d61c403cd56eac354d4195ff1e0ac920c0363b74

# Install GNOME desktop, gnome-remote-desktop, and openssl for TLS cert generation.
RUN dnf install -y \
        @gnome-desktop \
        gnome-remote-desktop \
        openssl \
    && dnf clean all

# Default to graphical login and enable GDM.
RUN systemctl set-default graphical.target && \
    systemctl enable gdm

# Set the default user password (lima/lima).
RUN echo "lima:lima" | chpasswd

# Install the firstboot RDP setup script and systemd service.
COPY setup-rdp.sh /usr/local/bin/setup-rdp.sh
RUN chmod +x /usr/local/bin/setup-rdp.sh

COPY gnome-rdp-setup.service /etc/systemd/system/gnome-rdp-setup.service

# Enable both the firstboot setup service and the system RDP daemon.
# gnome-rdp-setup runs once on first boot (before gnome-remote-desktop starts)
# to generate a TLS cert and store credentials. gnome-remote-desktop then
# listens on 3389 for RDP connections at the GDM login screen.
RUN systemctl enable gnome-rdp-setup.service && \
    systemctl enable gnome-remote-desktop.service
